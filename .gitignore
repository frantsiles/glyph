# ==============================================================
# Glyph — .gitignore
# ==============================================================

# ── Rust / Cargo ──────────────────────────────────────────────
/target/
**/*.rs.bk
# ── IDEs y editores ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Archivos de sistema ───────────────────────────────────────
Thumbs.db
desktop.ini

# ── Variables de entorno y secretos ──────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Logs y temporales ─────────────────────────────────────────
*.log
*.tmp

# ── Plugins compilados (WASM) — Milestone 3 ──────────────────
plugins/**/*.wasm
plugins/**/target/

# ── Cobertura de tests ────────────────────────────────────────
coverage/
lcov.info
tarpaulin-report.html
